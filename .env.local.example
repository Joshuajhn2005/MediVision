# API Configuration

# FastAPI backend URL
# Default: http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API timeout in milliseconds (default: 30000)
NEXT_PUBLIC_API_TIMEOUT=30000

# Upload timeout in milliseconds (default: 60000)
NEXT_PUBLIC_UPLOAD_TIMEOUT=60000

# Maximum file size in bytes (default: 104857600 = 100MB)
NEXT_PUBLIC_MAX_FILE_SIZE=104857600

# Development fallback mode
# When set to 'true', uses deterministic mock responses if backend unavailable
# Allows frontend development without backend completion
# Default: false
NEXT_PUBLIC_USE_MOCK_API=false
